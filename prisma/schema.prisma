generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String               @id
  email          String               @unique
  userName       String               @unique
  avatarUrl      String?
  totalXp        Int                  @default(10)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  name           String?
  speechAttempts SpeechAttempts[]
  lessonProgress UserLessonProgress[]

  @@map("users_table")
}

model Section {
  id      String   @id @default(cuid())
  title   String
  order   Int      @unique
  lessons Lesson[]

  @@map("level_table")
}

model Lesson {
  id           String               @id @default(cuid())
  title        String
  description  String?
  order        Int
  levelId      String
  isCompleted  Boolean              @default(false)
  content      LessonContent[]
  level        Section              @relation(fields: [levelId], references: [id])
  tasks        Task[]
  userProgress UserLessonProgress[]

  @@unique([levelId, order])
  @@map("lessons_table")
}

model LessonContent {
  id       String  @id @default(cuid())
  lessonId String
  name     String
  text     String
  imageUrl String?
  order    Int
  lesson   Lesson  @relation(fields: [lessonId], references: [id])

  @@map("lesson_contents_table")
}

model Task {
  id            String         @id @default(cuid())
  lessonId      String
  type          TaskType
  difficulty    TaskDifficulty
  xpReward      Int
  question      String
  correctAnswer String
  options       Json?
  order         Int
  lesson        Lesson         @relation(fields: [lessonId], references: [id])

  @@map("tasks_table")
}

model UserLessonProgress {
  id           String       @id @default(cuid())
  userId       String
  lessonId     String
  status       LessonStatus @default(LOCKED)
  mistakeCount Int          @default(3)
  xpEarned     Int          @default(0)
  completedAt  DateTime?
  lesson       Lesson       @relation(fields: [lessonId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

// schema.prisma

model SpeechTarget {
  id           String          @id @default(uuid())
  createdAt    DateTime        @default(now())
  title        String
  expectedText String
  wordsCount   Int
  attempts     SpeechAttempt[]

  @@map("speech_targets")
}

model SpeechAttempt {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  targetId String
  target   SpeechTarget @relation(fields: [targetId], references: [id])
  userId   String
  user     User         @relation(fields: [userId], references: [id])

  transcribedText String
  durationSec     Int

  mistakes       Int
  accuracy       Float
  wordsRead      Int
  charactersRead Int
  wpm            Int
  cpm            Int

  @@map("speech_attempts")
}

enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  MC
  TRANSLATE
  MATCH
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}
