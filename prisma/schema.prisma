generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                     @id
  email                String                     @unique
  userName             String                     @unique
  avatarUrl            String?
  totalXp              Int                        @default(10)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  name                 String?
  heartsRemaining      Int                        @default(5)
  speechAttempts       SpeechAttempt[]
  speechTargetProgress UserSpeechTargetProgress[]
  lessonProgress       UserLessonProgress[]

  @@index([totalXp(sort: Desc)])
  @@map("users_table")
}

model Section {
  id      String   @id @default(cuid())
  title   String
  order   Int      @unique
  lessons Lesson[]

  @@map("level_table")
}

model Lesson {
  id            String               @id @default(cuid())
  title         String
  description   String?
  order         Int
  levelId       String
  isCompleted   Boolean              @default(false)
  videoUrl      String?
  content       LessonContent[]
  level         Section              @relation(fields: [levelId], references: [id])
  speechTargets SpeechTarget[]
  tasks         Task[]
  userProgress  UserLessonProgress[]

  @@unique([levelId, order])
  @@map("lessons_table")
}

model LessonContent {
  id           String  @id @default(cuid())
  lessonId     String
  name         String
  text         String
  unicode      String?
  imageUrl     String?
  order        Int
  animationCss String?
  lesson       Lesson  @relation(fields: [lessonId], references: [id])

  @@map("lesson_contents_table")
}

model Task {
  id            String         @id @default(cuid())
  lessonId      String
  type          TaskType
  difficulty    TaskDifficulty
  xpReward      Int
  question      String
  correctAnswer String
  options       Json?
  order         Int
  lesson        Lesson         @relation(fields: [lessonId], references: [id])

  @@map("tasks_table")
}

model UserLessonProgress {
  id             String          @id @default(cuid())
  userId         String
  lessonId       String
  status         LessonStatus    @default(LOCKED)
  xpEarned       Int             @default(0)
  completedAt    DateTime?
  lesson         Lesson          @relation(fields: [lessonId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  speechAttempts SpeechAttempt[]

  @@unique([userId, lessonId])
  @@index([userId, status, completedAt])
  @@map("user_lesson_progress")
}

model SpeechTarget {
  id               String                     @id @default(uuid())
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  lessonId         String?
  lesson           Lesson?                    @relation(fields: [lessonId], references: [id])
  title            String
  description      String?
  difficulty       ReadingDifficulty          @default(EASY)
  requiredAccuracy Int?
  isRequired       Boolean                    @default(true)
  xpReward         Int                        @default(10)
  cyrillicText     String
  traditionalText  String
  wordsCount       Int
  attempts         SpeechAttempt[]
  progress         UserSpeechTargetProgress[]

  @@index([lessonId])
  @@map("speech_targets")
}

model SpeechAttempt {
  id                String                     @id @default(uuid())
  createdAt         DateTime                   @default(now())
  targetId          String
  userId            String
  lessonProgressId  String?
  transcribedText   String
  durationSec       Int
  mistakes          Int
  accuracy          Float
  coverage          Float                      @default(0)
  finalScore        Float                      @default(0)
  wordsRead         Int
  charactersRead    Int
  wpm               Int
  isPassed          Boolean                    @default(false)
  xpEarned          Int                        @default(0)
  bestForProgress   UserSpeechTargetProgress[] @relation("BestSpeechTargetProgressAttempt")
  latestForProgress UserSpeechTargetProgress[] @relation("LatestSpeechTargetProgressAttempt")
  lessonProgress    UserLessonProgress?        @relation(fields: [lessonProgressId], references: [id])
  target            SpeechTarget               @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user              User                       @relation(fields: [userId], references: [id])

  @@index([lessonProgressId])
  @@index([userId, targetId, createdAt])
  @@index([userId, targetId, accuracy])
  @@index([userId, targetId, isPassed])
  @@map("speech_attempts")
}

model UserSpeechTargetProgress {
  id              String         @id @default(cuid())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  targetId        String
  latestAttemptId String?
  bestAttemptId   String?
  passedAt        DateTime?
  isPassed        Boolean        @default(false)
  xpEarned        Int            @default(0)
  bestAccuracy    Float?
  latestAccuracy  Float?
  bestAttempt     SpeechAttempt? @relation("BestSpeechTargetProgressAttempt", fields: [bestAttemptId], references: [id], onDelete: SetNull)
  latestAttempt   SpeechAttempt? @relation("LatestSpeechTargetProgressAttempt", fields: [latestAttemptId], references: [id], onDelete: SetNull)
  target          SpeechTarget   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetId])
  @@index([userId, isPassed])
  @@index([targetId])
  @@index([bestAttemptId])
  @@index([latestAttemptId])
  @@map("user_speech_target_progress")
}

enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  MC
  TRANSLATE
  MATCH
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ReadingDifficulty {
  EASY
  MEDIUM
  HARD
}
