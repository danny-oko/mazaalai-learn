datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  MC
  TRANSLATE
  MATCH
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id             String               @id // clerkId from Clerk Auth
  email          String               @unique
  displayName    String               
  userName       String               @unique 
  avatarUrl      String?
  
  // UI Stats
  totalXp        Int                  @default(10)
  globalRanking  Int?                 // League position
  streak         Int                  @default(0)  // Flame icon
  
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  
  lessonProgress UserLessonProgress[]
  speechAttempts SpeechAttempts[]

  @@map("users_table")
}

model Section {
  id      String   @id @default(cuid())
  title   String   // "Basics 1"
  order   Int      @unique
  lessons Lesson[]

  @@map("level_table")
}

model Lesson {
  id           String               @id @default(cuid())
  title        String
  description  String?
  order        Int
  isCompleted  Boolean              @default(false)
  levelId      String
  level        Section                @relation(fields: [levelId], references: [id])
  
  // Relations
  content      LessonContent[]      // The "Teaching" items
  tasks        Task[]               // The exercises/quizzes
  userProgress UserLessonProgress[]

  @@unique([levelId, order])
  @@map("lessons_table")
}

model LessonContent {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  
  name        String   // e.g., "The letter 'A'" or "Past Tense"
  text        String   // The actual character or core item being taught
  // audioUrl    String?  // Optional: for pronunciation
  imageUrl    String?  // Optional: for visual aids
  
  order       Int      // Sequence to show these items within the lesson teaching phase

  @@map("lesson_contents_table")
}

model Task {
  id            String         @id @default(cuid())
  lessonId      String
  lesson        Lesson         @relation(fields: [lessonId], references: [id])
  type          TaskType
  difficulty    TaskDifficulty
  xpReward      Int            // 3, 5, or 10
  question      String
  correctAnswer String
  options       Json?          
  order         Int            

  @@map("tasks_table")
}

model UserLessonProgress {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  lessonId     String
  lesson       Lesson       @relation(fields: [lessonId], references: [id])
  status       LessonStatus @default(LOCKED)
  mistakeCount Int          @default(3) // 0-3 "Hearts"
  xpEarned     Int          @default(0)
  completedAt  DateTime?

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model SpeechTargets {
  id           String   @id @default(uuid())
  title        String
  expectedText String
  wordsCount   Int
  createdAt    DateTime @default(now())
  attempts     SpeechAttempts[]
}

model SpeechAttempts {
  id              String   @id @default(uuid())
  userId          String
  targetId        String
  transcribedText String
  wordsRead       Int
  createdAt       DateTime @default(now())

  target          SpeechTargets @relation(fields: [targetId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}