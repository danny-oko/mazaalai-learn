// This is your Prisma schema file
datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


//  enums for tables
enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  READ
  QUIZ_SELECTION
  CONVERT
  MATCHING
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

// Tables
model User {
  id             String               @id
  name           String
  email          String               @unique
  userName       String
  avatarUrl      String?
  totalXp        Int                  @default(10)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  lessonProgress UserLessonProgress[]

  @@map("users_table")
}

model Level {
  id      String   @id @default(cuid())
  title   String
  order   Int      @unique // Dashboard der heded orj bgagin haruulah too
  lessons Lesson[]

  @@map("level_table")
}

model Lesson {
  id           String               @id @default(cuid())
  title        String
  description  String?
  order        Int
  levelId      String
  level        Level                @relation(fields: [levelId], references: [id])
  tasks        Task[]
  userProgress UserLessonProgress[]

  @@unique([levelId, order])
  @@map("lessons_table")
}

model Task {
  id            String         @id @default(cuid())
  lessonId      String
  lesson        Lesson         @relation(fields: [lessonId], references: [id])
  type          TaskType
  difficulty    TaskDifficulty
  xpReward      Int // negj task bolgon heden xp uguh ve (aldval: 0, zuv hiisn: 15xp geh met)
  question      String
  correctAnswer String
  options       Json? // List of choices for MC or Matching
  order         Int // Sequence within the lesson

  @@map("tasks_table")
}

model UserLessonProgress {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  lessonId     String
  lesson       Lesson       @relation(fields: [lessonId], references: [id])
  status       LessonStatus @default(LOCKED)
  mistakeCount Int          @default(0) // 0-3 management (3 udaa aldval lesson oo ehnees ni ehluulne)
  xpEarned     Int          @default(0)
  completedAt  DateTime?

  @@unique([userId, lessonId]) // One progress record per user per lesson
  @@map("user_lesson_progress")
}

model SpeechTargets {
  id            String           @id @default(uuid())
  expected_text String
  created_at    DateTime         @default(now())

  attempts      SpeechAttempts[]
}

model SpeechAttempts {
  id                String       @id @default(uuid())
  user_id           String
  imageUrl          String
  target_id         String
  transcribed_text  String
  accuracy_score    Int
  created_at        DateTime     @default(now())

  target            SpeechTargets @relation(fields: [target_id], references: [id])
}
