generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String               @id
  email           String               @unique
  userName        String               @unique
  avatarUrl       String?
  totalXp         Int                  @default(10)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  name            String?
  heartsRemaining Int                  @default(5)
  speechAttempts  SpeechAttempt[]
  lessonProgress  UserLessonProgress[]

  @@index([totalXp(sort: Desc)])
  @@map("users_table")
}

model Section {
  id      String   @id @default(cuid())
  title   String
  order   Int      @unique
  lessons Lesson[]

  @@map("level_table")
}

model Lesson {
  id           String               @id @default(cuid())
  title        String
  description  String?
  order        Int
  levelId      String
  isCompleted  Boolean              @default(false)
  videoUrl     String?
  content      LessonContent[]
  level        Section              @relation(fields: [levelId], references: [id])
  tasks        Task[]
  userProgress UserLessonProgress[]

  @@unique([levelId, order])
  @@map("lessons_table")
}

model LessonContent {
  id           String  @id @default(cuid())
  lessonId     String
  name         String
  text         String
  imageUrl     String?
  animationCss String?
  order        Int
  lesson       Lesson  @relation(fields: [lessonId], references: [id])

  @@map("lesson_contents_table")
}

model Task {
  id            String         @id @default(cuid())
  lessonId      String
  type          TaskType
  difficulty    TaskDifficulty
  xpReward      Int
  question      String
  correctAnswer String
  options       Json?
  order         Int
  lesson        Lesson         @relation(fields: [lessonId], references: [id])

  @@map("tasks_table")
}

model UserLessonProgress {
  id          String       @id @default(cuid())
  userId      String
  lessonId    String
  status      LessonStatus @default(LOCKED)
  xpEarned    Int          @default(0)
  completedAt DateTime?
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}


model SpeechTarget {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title            String
  description      String?
  difficulty       ReadingDifficulty @default(EASY)
  requiredAccuracy Int?
  cyrillicText    String
  traditionalText String
  wordsCount       Int
  attempts         SpeechAttempt[]

  @@map("speech_targets")
}

model SpeechAttempt {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  targetId String
  target   SpeechTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  userId   String
  user     User         @relation(fields: [userId], references: [id])

  transcribedText String
  durationSec     Int

  // Computed results — store these so you never need to recalculate
  mistakes       Int
  accuracy       Float
  wordsRead      Int
  charactersRead Int
  wpm            Int

  @@map("speech_attempts")
}

enum LessonStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

enum TaskType {
  MC
  TRANSLATE
  MATCH
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ReadingDifficulty {
  EASY
  MEDIUM
  HARD
}
