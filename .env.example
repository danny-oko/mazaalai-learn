# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Custom auth pages (required for custom /sign-in and /sign-up routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Prefer these (Clerk’s current names); AFTER_SIGN_* is deprecated but still works if set.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/home
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/home

# OAuth: in Clerk Dashboard → configure allowed redirect URLs, e.g.
#   http://localhost:3000/sso-callback
#   https://your-production-domain/sso-callback
